<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Geoffrey Moreno — Creative Strategist</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="style.css?v=20260506-2">
  <style>
    /* ══ PODIUM HERO ══ */
    .podium-stage {
      position: relative;
      width: 614px;
      height: 566px;
      flex-shrink: 0;
      transform: translate(20%, 5%) scale(1.03);
    }
    #podium-canvas {
      width: 100%;
      height: 100%;
      display: block;
      position: absolute;
      inset: 0;
    }
    .stage-loading {
      position: absolute; inset: 0;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Poppins', sans-serif;
      font-size: 13px; letter-spacing: 0.1em; text-transform: uppercase;
      color: rgba(0,0,0,0.4); pointer-events: none;
      transition: opacity 0.4s ease;
    }
    .stage-loading.is-hidden { opacity: 0; }
    .podium-stage:not(.is-ready) .active-label { opacity: 0; }
    .active-label {
      transition: opacity 0.4s ease 0.2s;
    }
    .active-label {
      position: absolute; top: 20px; left: 50%; transform: translateX(-50%);
      font-family: 'PoppinsEB', 'Poppins', sans-serif;
      font-size: 14px; letter-spacing: 0.18em; text-transform: uppercase;
      color: #1a1a1a;
      padding: 10px 22px;
      background: rgba(255,255,255,0.7);
      backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
      border: 1px solid rgba(0,0,0,0.08);
      border-radius: 999px;
      transition: opacity 0.35s ease, transform 0.35s ease;
      pointer-events: none;
    }
    .active-label { --dir: 1; }
    .active-label.is-leaving {
      animation: label-slide-out 520ms cubic-bezier(0.5, 0, 0.2, 1) forwards;
    }
    .active-label.is-entering {
      animation: label-slide-in 380ms cubic-bezier(0.18, 0.9, 0.25, 1) both;
    }
    @keyframes label-slide-out {
      0%   { opacity: 1; transform: translateX(-50%) translateX(0) scale(1); }
      100% { opacity: 0; transform: translateX(-50%) translateX(calc(var(--dir) * 36px)) scale(0.94); }
    }
    @keyframes label-slide-in {
      0%   { opacity: 0; transform: translateX(-50%) translateX(calc(var(--dir) * -36px)) scale(0.94); }
      60%  { opacity: 1; }
      100% { opacity: 1; transform: translateX(-50%) translateX(0) scale(1); }
    }
    .active-label.is-badge {
      padding: 10px 18px 10px 14px;
      font-size: 11.4px; letter-spacing: 0.04em; text-transform: none;
      color: #ffffff;
      border: 1px solid rgba(132, 188, 255, 0.22);
      background:
        radial-gradient(ellipse at 15% -20%, rgba(61,208,255,0.32) 0%, transparent 60%),
        radial-gradient(ellipse at 90% 120%, rgba(175,125,255,0.22) 0%, transparent 55%),
        linear-gradient(120deg, #001E54 0%, #003791 45%, #0070D1 75%, #003791 100%);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.18),
        inset 0 -1px 0 rgba(0,0,0,0.25),
        0 8px 24px rgba(0, 55, 145, 0.45),
        0 2px 6px rgba(0,0,0,0.28);
      border-radius: 10px;
      display: inline-flex; align-items: center; gap: 10px;
      font-family: 'Poppins', sans-serif; font-weight: 600;
      overflow: visible;
      text-shadow: 0 1px 2px rgba(0, 8, 31, 0.55);
    }
    .active-label.is-badge .ps-symbols {
      position: absolute; inset: 0; pointer-events: none;
      overflow: hidden; border-radius: inherit;
    }
    .active-label.is-badge .ps-symbol {
      position: absolute; font-family: 'Poppins', sans-serif;
      font-weight: 700; line-height: 1; user-select: none;
    }
    .active-label.is-badge .ps-symbol--triangle { color: rgba(143,235,184,0.85); text-shadow: 0 0 6px rgba(143,235,184,0.55), 0 1px 2px rgba(0,0,0,0.4); }
    .active-label.is-badge .ps-symbol--circle   { color: rgba(255,142,142,0.85); text-shadow: 0 0 6px rgba(255,142,142,0.55), 0 1px 2px rgba(0,0,0,0.4); }
    .active-label.is-badge .ps-symbol--cross     { color: rgba(132,188,255,0.95); text-shadow: 0 0 6px rgba(132,188,255,0.65), 0 1px 2px rgba(0,0,0,0.4); }
    .active-label.is-badge .ps-symbol--square    { color: rgba(238,168,235,0.85); text-shadow: 0 0 6px rgba(238,168,235,0.55), 0 1px 2px rgba(0,0,0,0.4); }
    .active-label.is-badge::after {
      content: ''; position: absolute; top: 0; left: -60%;
      width: 50%; height: 100%;
      background: linear-gradient(100deg, transparent 20%, rgba(255,255,255,0.18) 50%, transparent 80%);
      transform: skewX(-18deg); pointer-events: none; opacity: 0;
    }
    .active-label.is-badge.is-revealing::after {
      animation: trophy-sheen 1100ms cubic-bezier(0.25, 0.8, 0.25, 1) 720ms both;
    }
    .active-label.is-badge .trophy-circle {
      position: relative; width: 22px; height: 22px; border-radius: 50%;
      background: linear-gradient(180deg, #f5d76e 0%, #d4a017 100%);
      display: flex; align-items: center; justify-content: center; font-size: 13px;
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.5), inset 0 -1px 0 rgba(0,0,0,0.2),
        0 0 0 2px rgba(245,215,110,0.18), 0 0 8px rgba(245,215,110,0.0);
      flex-shrink: 0;
    }
    .active-label.is-badge.is-revealing .trophy-circle {
      animation: trophy-circle-pop 700ms cubic-bezier(0.34, 1.56, 0.64, 1) 180ms both,
                 trophy-glow 2400ms ease-in-out 1100ms infinite;
    }
    .active-label.is-badge .sparkle {
      position: absolute; width: 4px; height: 4px; border-radius: 50%;
      background: radial-gradient(circle, #fff8d4 0%, #f5d76e 50%, transparent 100%);
      pointer-events: none; opacity: 0; left: 50%; top: 50%;
      box-shadow: 0 0 6px rgba(245,215,110,0.9);
    }
    .active-label.is-badge.is-revealing .sparkle {
      animation: sparkle-burst 900ms cubic-bezier(0.2, 0.8, 0.4, 1) 280ms both;
    }
    .active-label.is-badge .trophy-circle::before {
      content: ''; position: absolute; inset: -6px; border-radius: 50%;
      background: radial-gradient(circle, rgba(255,255,255,0.9) 0%, rgba(255,255,255,0) 70%);
      opacity: 0; pointer-events: none;
    }
    .active-label.is-badge .trophy-text { display: inline-block; white-space: nowrap; overflow: hidden; }
    .brand-chip {
      position: absolute; bottom: calc(100% + 8px); left: 50%; transform: translateX(-50%);
      padding: 5px 12px; border-radius: 6px;
      display: inline-flex; align-items: center; justify-content: center;
      pointer-events: none; opacity: 0;
      transition: opacity 280ms ease-out 220ms;
    }
    .active-label.is-badge.is-revealing .brand-chip { opacity: 1; }
    .brand-chip .brand-logo { height: auto; display: block; }
    .brand-chip.is-ps {
      border: 1px solid rgba(132,188,255,0.30);
      background: radial-gradient(ellipse at 30% -30%, rgba(61,208,255,0.30) 0%, transparent 70%),
        linear-gradient(120deg, #001E54 0%, #003791 60%, #0070D1 100%);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.18), 0 4px 12px rgba(0,55,145,0.45), 0 1px 3px rgba(0,0,0,0.25);
    }
    .brand-chip.is-ps .brand-logo { width: 80px; filter: brightness(0) invert(1) drop-shadow(0 1px 1px rgba(0,0,0,0.4)); }
    .brand-chip.is-netflix {
      border: 1px solid rgba(255,90,95,0.32);
      background: radial-gradient(ellipse at 30% -30%, rgba(255,100,100,0.32) 0%, transparent 70%),
        linear-gradient(120deg, #1a0000 0%, #5a0a0e 45%, #B81D24 100%);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.18), 0 4px 12px rgba(229,9,20,0.45), 0 1px 3px rgba(0,0,0,0.32);
    }
    .brand-chip.is-netflix .brand-logo { width: 56px; filter: brightness(0) invert(1) drop-shadow(0 1px 1px rgba(0,0,0,0.45)); }
    .brand-chip.is-universal {
      border: 1px solid rgba(140,175,255,0.28);
      background: radial-gradient(ellipse at 30% -30%, rgba(120,165,255,0.32) 0%, transparent 70%),
        linear-gradient(120deg, #050B26 0%, #0E1A4A 45%, #1B2A6B 100%);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.16), 0 4px 12px rgba(14,26,74,0.55), 0 1px 3px rgba(0,0,0,0.32);
      padding: 4px 10px;
    }
    .brand-chip.is-universal .brand-logo { width: 68px; filter: drop-shadow(0 1px 2px rgba(0,0,0,0.55)); }
    .brand-chip .brand-wordmark {
      font-family: 'PoppinsEB', 'Poppins', sans-serif; font-weight: 900;
      font-size: 11.5px; letter-spacing: 0.18em; color: #ffffff; line-height: 1;
      text-shadow: 0 1px 2px rgba(0,0,0,0.5);
    }
    .brand-chip.is-netflix .brand-wordmark { color: #fff; text-shadow: 0 1px 2px rgba(80,0,0,0.7); }
    .active-label.is-badge .trophy-text .char { display: inline-block; opacity: 0; transform: translateY(2px); }
    @keyframes trophy-slide-in {
      0%   { opacity: 0; transform: translateX(-50%) translateX(calc(var(--dir) * -38px)) translateY(8px)  scale(0.92) rotate(calc(var(--dir) * -5deg)); }
      55%  { opacity: 1; transform: translateX(-50%) translateX(calc(var(--dir) *  4px)) translateY(-3px) scale(1.03) rotate(calc(var(--dir) * 1.8deg)); }
      75%  { opacity: 1; transform: translateX(-50%) translateX(calc(var(--dir) * -1px)) translateY(1px)  scale(0.99) rotate(calc(var(--dir) * -0.5deg)); }
      100% { opacity: 1; transform: translateX(-50%) translateX(0) translateY(0) scale(1) rotate(0deg); }
    }
    @keyframes trophy-flash {
      0%   { opacity: 0; transform: scale(0.4); }
      50%  { opacity: 1; transform: scale(1); }
      100% { opacity: 0; transform: scale(1.6); }
    }
    @keyframes trophy-circle-pop {
      0%   { transform: scale(0.2) rotate(-25deg); }
      60%  { transform: scale(1.18) rotate(8deg); }
      100% { transform: scale(1) rotate(0); }
    }
    @keyframes char-reveal {
      0%   { opacity: 0; transform: translateY(6px); }
      100% { opacity: 1; transform: translateY(0); }
    }
    @keyframes trophy-sheen {
      0%   { left: -60%; opacity: 0; }
      30%  { opacity: 1; }
      100% { left: 130%; opacity: 0; }
    }
    @keyframes trophy-glow {
      0%, 100% { box-shadow: inset 0 1px 0 rgba(255,255,255,0.5), inset 0 -1px 0 rgba(0,0,0,0.2), 0 0 0 2px rgba(245,215,110,0.18), 0 0 8px rgba(245,215,110,0.0); }
      50%       { box-shadow: inset 0 1px 0 rgba(255,255,255,0.5), inset 0 -1px 0 rgba(0,0,0,0.2), 0 0 0 3px rgba(245,215,110,0.30), 0 0 14px rgba(245,215,110,0.55); }
    }
    @keyframes sparkle-burst {
      0%   { opacity: 0; transform: translate(-50%, -50%) translate(0, 0) scale(0.4); }
      30%  { opacity: 1; }
      100% { opacity: 0; transform: translate(-50%, -50%) translate(var(--dx), var(--dy)) scale(0.2); }
    }
    .active-label.is-badge.is-revealing {
      animation: trophy-slide-in 720ms cubic-bezier(0.18, 0.9, 0.25, 1) both,
                 trophy-levitate 4200ms ease-in-out 720ms infinite;
    }
    @keyframes trophy-levitate {
      0%, 100% { transform: translateX(-50%) translateY(0) scale(1) rotate(0deg); box-shadow: inset 0 1px 0 rgba(255,255,255,0.18), inset 0 -1px 0 rgba(0,0,0,0.25), 0 8px 24px rgba(0,55,145,0.45), 0 2px 6px rgba(0,0,0,0.28); }
      50%       { transform: translateX(-50%) translateY(-5px) scale(1) rotate(0deg); box-shadow: inset 0 1px 0 rgba(255,255,255,0.18), inset 0 -1px 0 rgba(0,0,0,0.25), 0 16px 36px rgba(0,55,145,0.55), 0 4px 10px rgba(0,0,0,0.32); }
    }
    .active-label.is-badge.is-revealing .trophy-circle { animation: trophy-circle-pop 700ms cubic-bezier(0.34, 1.56, 0.64, 1) 180ms both; }
    .active-label.is-badge.is-revealing .trophy-circle::before { animation: trophy-flash 650ms ease-out 220ms both; }
    .active-label.is-badge.is-revealing .trophy-text .char {
      animation: char-reveal 420ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
      animation-delay: calc(380ms + var(--i) * 22ms);
    }
    .active-label.is-badge.is-netflix {
      border: 1px solid rgba(255,90,95,0.22);
      background: radial-gradient(ellipse at 15% -20%, rgba(255,100,100,0.32) 0%, transparent 60%),
        radial-gradient(ellipse at 90% 120%, rgba(180,30,40,0.28) 0%, transparent 55%),
        linear-gradient(120deg, #0a0000 0%, #5a0a0e 45%, #B81D24 75%, #5a0a0e 100%);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.18), inset 0 -1px 0 rgba(0,0,0,0.32), 0 8px 24px rgba(229,9,20,0.42), 0 2px 6px rgba(0,0,0,0.32);
      text-shadow: 0 1px 2px rgba(40,0,0,0.65);
    }
    .active-label.is-badge.is-netflix .trophy-circle {
      background: radial-gradient(circle at 30% 25%, #ffe89a 0%, #f5d76e 35%, #d49b2a 70%, #8a5a0f 100%);
      border-color: rgba(255,220,140,0.85);
    }
    .active-label.is-badge.is-netflix.is-revealing {
      animation: trophy-slide-in 720ms cubic-bezier(0.18, 0.9, 0.25, 1) both,
                 trophy-levitate-netflix 4200ms ease-in-out 720ms infinite;
    }
    @keyframes trophy-levitate-netflix {
      0%, 100% { transform: translateX(-50%) translateY(0) scale(1) rotate(0deg); box-shadow: inset 0 1px 0 rgba(255,255,255,0.18), inset 0 -1px 0 rgba(0,0,0,0.32), 0 8px 24px rgba(229,9,20,0.42), 0 2px 6px rgba(0,0,0,0.32); }
      50%       { transform: translateX(-50%) translateY(-5px) scale(1) rotate(0deg); box-shadow: inset 0 1px 0 rgba(255,255,255,0.18), inset 0 -1px 0 rgba(0,0,0,0.32), 0 16px 36px rgba(229,9,20,0.55), 0 4px 10px rgba(0,0,0,0.36); }
    }
    .active-label.is-badge.is-universal {
      border: 1px solid rgba(140,175,255,0.22);
      background: radial-gradient(ellipse at 15% -20%, rgba(120,165,255,0.28) 0%, transparent 60%),
        radial-gradient(ellipse at 90% 120%, rgba(75,100,200,0.22) 0%, transparent 55%),
        linear-gradient(120deg, #050B26 0%, #0E1A4A 45%, #1B2A6B 75%, #0E1A4A 100%);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.18), inset 0 -1px 0 rgba(0,0,0,0.3), 0 8px 24px rgba(14,26,74,0.5), 0 2px 6px rgba(0,0,0,0.3);
      text-shadow: 0 1px 2px rgba(0,5,30,0.7);
    }
    .active-label.is-badge.is-universal .trophy-circle {
      background: radial-gradient(circle at 30% 25%, #ffe89a 0%, #f5d76e 35%, #d49b2a 70%, #8a5a0f 100%);
      border-color: rgba(255,220,140,0.85);
    }
    .active-label.is-badge.is-universal.is-revealing {
      animation: trophy-slide-in 720ms cubic-bezier(0.18, 0.9, 0.25, 1) both,
                 trophy-levitate-universal 4200ms ease-in-out 720ms infinite;
    }
    @keyframes trophy-levitate-universal {
      0%, 100% { transform: translateX(-50%) translateY(0) scale(1) rotate(0deg); box-shadow: inset 0 1px 0 rgba(255,255,255,0.18), inset 0 -1px 0 rgba(0,0,0,0.3), 0 8px 24px rgba(14,26,74,0.5), 0 2px 6px rgba(0,0,0,0.3); }
      50%       { transform: translateX(-50%) translateY(-5px) scale(1) rotate(0deg); box-shadow: inset 0 1px 0 rgba(255,255,255,0.18), inset 0 -1px 0 rgba(0,0,0,0.3), 0 16px 36px rgba(14,26,74,0.65), 0 4px 10px rgba(0,0,0,0.36); }
    }
    .podium-nav {
      position: absolute; bottom: 16px; left: 50%; transform: translateX(-50%);
      display: flex; align-items: center; gap: 56px; z-index: 5;
    }
    .podium-nav__arrow {
      width: 36px; height: 36px; border-radius: 50%;
      border: 1px solid rgba(0,0,0,0.18);
      background: rgba(255,255,255,0.6);
      backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
      color: rgba(0,0,0,0.7); cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: border-color 0.22s ease, background 0.22s ease, color 0.22s ease, transform 0.22s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .podium-nav__arrow svg { width: 12px; height: 12px; stroke: currentColor; stroke-width: 2.4; stroke-linecap: round; stroke-linejoin: round; fill: none; transition: transform 0.28s cubic-bezier(0.34, 1.56, 0.64, 1); }
    .podium-nav__arrow:hover { border-color: rgba(0,0,0,0.5); background: rgba(255,255,255,0.95); color: rgba(0,0,0,1); transform: scale(1.08); }
    .podium-nav__arrow#prevBtn:hover svg { transform: translateX(-2px); }
    .podium-nav__arrow#nextBtn:hover svg { transform: translateX(2px); }
    .podium-nav__arrow:active { transform: scale(0.94); }
    .podium-nav__arrow:disabled { opacity: 0.3; cursor: default; transform: none; }
    .podium-nav__sep, .podium-nav__dots { display: none; }
    .video-pool { position: absolute; width: 1px; height: 1px; opacity: 0; pointer-events: none; left: -9999px; }

    /* ─── Contrôles vidéo (centre uniquement) ─── */
    .phone-controls {
      position: absolute;
      left: 50%;
      top: 50%;
      width: 152px;   /* largeur ≈ écran iPhone central rendu */
      height: 320px;  /* hauteur ≈ écran iPhone central rendu */
      transform: translate(-50%, -50%);
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.35s ease;
      z-index: 4;
    }
    .podium-stage.is-ready:not(.is-cycling) .phone-controls { opacity: 1; }
    /* Bouton son en haut GAUCHE de l'écran */
    .phone-ctrl__sound {
      position: absolute;
      top: 12px; left: 12px;
      width: 30px; height: 30px;
      border-radius: 50%;
      border: 1px solid rgba(255,255,255,0.30);
      background: rgba(0,0,0,0.42);
      backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
      color: #fff;
      cursor: pointer;
      pointer-events: auto;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.2s ease, transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .phone-ctrl__sound:hover { background: rgba(0,0,0,0.65); transform: scale(1.08); }
    .phone-ctrl__sound:active { transform: scale(0.94); }
    .phone-ctrl__sound svg { width: 14px; height: 14px; fill: currentColor; }
    .phone-ctrl__sound .icon-mute   { display: none; }
    .phone-controls.is-muted .phone-ctrl__sound .icon-mute { display: block; }
    .phone-controls.is-muted .phone-ctrl__sound .icon-on   { display: none; }

    @media (max-width: 1100px) {
      .podium-stage { width: 440px; height: 420px; }
    }
    @media (max-width: 900px) {
      .podium-stage { width: min(520px, 90vw); height: 400px; }
    }
  </style>
</head>
<body>

  <!-- ══ HEADER ══ -->
  <header class="header">
    <div class="header-pill">

    <!-- Gauche : logo -->
    <a href="index.html" class="header-logo">GEOFFREY MORENO</a>

    <!-- Centre : navigation -->
    <nav class="header-nav">
      <a href="index.html" class="nav-link" data-nav="projets">Mes projets</a>
      <a href="mon-parcours.html" class="nav-link" data-nav="parcours">Mon parcours</a>
      <a href="me-contacter.html" class="nav-link" data-nav="contact">Me contacter</a>
    </nav>

    <!-- Droite : icônes sociales -->
    <div class="header-socials">
      <a href="#" class="social-link" aria-label="LinkedIn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
      <a href="#" class="social-link" aria-label="TikTok">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.72a8.27 8.27 0 004.84 1.56V6.83a4.85 4.85 0 01-1.07-.14z"/>
        </svg>
      </a>
      <a href="#" class="social-link" aria-label="Instagram">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
